{
  "name": "cp-program-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:schemas": "node ../../../shared/schemas/generate-json-schema.mjs",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/*.test.js",
    "test:neo4j": "node --test tests/program-manager-graph-neo4j.test.js",
    "smoke:neo4j": "node scripts/run-neo4j-smoke.mjs",
    "pmo:doctor": "node scripts/pmo-doctor.mjs",
    "pmo:replay-smoke": "node scripts/pmo-replay-smoke.mjs",
    "pmo:report-regenerate": "node scripts/pmo-report-regenerate.mjs",
    "pmo:adapter-conformance": "node scripts/pmo-adapter-conformance.mjs",
    "pmo:phase4-smoke": "node scripts/pmo-phase4-smoke.mjs",
    "pmo:mcp-runtime-smoke": "node --test tests/mcp-server-restart-smoke.test.js",
    "pmo:mcp-restart-smoke": "node --test tests/mcp-server-restart-smoke.test.js",
    "pmo:agent-loop-proof": "node --test tests/agent-owned-pmo-loop-smoke.test.js",
    "pmo:otel-smoke": "node scripts/pmo-otel-smoke.mjs"
  },
  "dependencies": {
    "neo4j-driver": "^5.28.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
